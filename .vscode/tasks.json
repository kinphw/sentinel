{
  "version": "2.0.0",
  "tasks": [
    {
      // 5173/3101에 잔여 프로세스가 남았을 때 죽이는 안전망. launch.json의 postDebugTask로 사용.
      "label": "Sentinel: Cleanup Ports",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$ports = 5173, 3101; $procIds = Get-NetTCPConnection -State Listen -ErrorAction SilentlyContinue | Where-Object { $_.LocalPort -in $ports } | Select-Object -ExpandProperty OwningProcess -Unique; foreach ($procId in $procIds) { Stop-Process -Id $procId -Force -ErrorAction SilentlyContinue }"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      }
    },
    {
      "label": "Sentinel: Build Backend",
      "type": "npm",
      "script": "build",
      "path": "backend",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "build"
    },
    {
      "label": "Sentinel: Build Frontend",
      "type": "npm",
      "script": "build",
      "path": "frontend",
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": { "SENTINEL_BACKEND_PORT": "3101" }
      },
      "group": "build"
    },
    {
      "label": "Sentinel: Build All",
      "dependsOrder": "sequence",
      "dependsOn": ["Sentinel: Build Backend", "Sentinel: Build Frontend"],
      "group": "build"
    }
  ]
}
