{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Sentinel: Cleanup Ports",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$ports = 5173, 3101; $procIds = Get-NetTCPConnection -State Listen -ErrorAction SilentlyContinue | Where-Object { $_.LocalPort -in $ports } | Select-Object -ExpandProperty OwningProcess -Unique; foreach ($procId in $procIds) { Stop-Process -Id $procId -Force -ErrorAction SilentlyContinue }"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      }
    },
    {
      "label": "Sentinel: Wait Backend",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$deadline = (Get-Date).AddSeconds(60); do { try { $res = Invoke-WebRequest -UseBasicParsing -Uri 'http://localhost:3101/api/runtime' -TimeoutSec 2; if ($res.StatusCode -ge 200 -and $res.StatusCode -lt 500) { exit 0 } } catch { }; Start-Sleep -Milliseconds 500 } while ((Get-Date) -lt $deadline); Write-Error 'Sentinel backend did not become ready on http://localhost:3101/api/runtime'; exit 1"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      }
    },
    {
      "label": "Sentinel: Frontend Dev",
      "type": "process",
      "command": "npm.cmd",
      "args": [
        "run",
        "dev",
        "--",
        "--port",
        "5173"
      ],
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "SENTINEL_BACKEND_PORT": "3101"
        }
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^((?!)x)$",
          "file": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:\\s+http://localhost:5173/"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "sentinel",
        "close": true
      }
    },
    {
      "label": "Sentinel: Stack",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Sentinel: Cleanup Ports",
        "Sentinel: Frontend Dev"
      ]
    },
    {
      "label": "Sentinel: Build Backend",
      "type": "npm",
      "script": "build",
      "path": "backend",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build"
    },
    {
      "label": "Sentinel: Build Frontend",
      "type": "npm",
      "script": "build",
      "path": "frontend",
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "SENTINEL_BACKEND_PORT": "3101"
        }
      },
      "group": "build"
    },
    {
      "label": "Sentinel: Build All",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Sentinel: Build Backend",
        "Sentinel: Build Frontend"
      ],
      "group": "build"
    }
  ]
}
